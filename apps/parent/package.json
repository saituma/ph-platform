{
  "name": "parent",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env.local -- vite dev",
    "build:deps": "pnpm --dir ../.. --filter @ph/roles build && pnpm --dir ../.. --filter @ph/auth build",
    "prebuild": "pnpm run build:deps",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite preview",
    "pretest": "pnpm run build:deps",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "pretypecheck": "pnpm run build:deps",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ph/auth": "workspace:*",
    "@ph/roles": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@t3-oss/env-core": "^0.13.10",
    "@tabler/icons-react": "^3.43.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.10.2",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-start": "^1.167.65",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "jose": "^5.10.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5"
  }
