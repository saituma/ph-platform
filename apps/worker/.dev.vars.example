# Copy to `.dev.vars` for `pnpm dev` / `wrangler dev` (never commit `.dev.vars`).
# Values must match Neon + the API where you issue app JWTs.

# Neon (same DB as apps/api — Better Auth tables + public.users)
DATABASE_URL=

# Better Auth signing secret (generate a long random string; not JWT_SECRET)
BETTER_AUTH_SECRET=

# Public URL of this worker (wrangler prints it in dev, e.g. http://127.0.0.1:8787)
BETTER_AUTH_URL=http://127.0.0.1:8787

# Must match apps/api JWT_SECRET — used to mint HS256 tokens for Express
JWT_SECRET=

# Optional: comma-separated browser origins (onboarding, Next.js web, etc.)
# TRUSTED_ORIGINS_EXTRA=http://localhost:3000,http://localhost:3001

# Optional: dev only — mirrors API ALLOW_EXPIRED_TOKENS
# ALLOW_EXPIRED_TOKENS=1

# Optional: require verified email before session (needs Better Auth email + SMTP)
# REQUIRE_EMAIL_VERIFICATION=1
