{
  "expo": {
    "entryPoint": "expo-router/entry",
    "name": "PH Performance",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIStatusBarHidden": true,
        "UIViewControllerBasedStatusBarAppearance": false
      },
      "bundleIdentifier": "com.clientreachai.phperformance"
    },
    "androidStatusBar": {
      "hidden": true,
      "translucent": true,
      "backgroundColor": "#00000000"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0b",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.clientreachai.phperformance",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-maps",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0b",
          "dark": {
            "backgroundColor": "#0a0a0b"
          }
        }
      ],
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PH Performance to access your photos and videos so you can send them in messages.",
          "cameraPermission": "Allow PH Performance to access your camera so you can take photos and record videos to send in messages."
        }
      ],
      [
        "expo-image",
        {}
      ],
      "expo-secure-store",
      "expo-video",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow this app to track your location during runs.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "PHSummary",
              "label": "PH Performance Summary",
              "description": "See your training progress and next session at a glance.",
              "resourceName": "ph_summary_widget"
            },
            {
              "name": "PHNextSession",
              "label": "PH Next Session",
              "description": "View your upcoming training session.",
              "resourceName": "ph_next_session_widget"
            },
            {
              "name": "PHWeeklyStats",
              "label": "PH Weekly Stats",
              "description": "Track your weekly running and training goals.",
              "resourceName": "ph_weekly_stats_widget"
            },
            {
              "name": "PHCurrentModule",
              "label": "PH Current Module",
              "description": "See which training module you are currently working on.",
              "resourceName": "ph_current_module_widget"
            },
            {
              "name": "PHSchedule",
              "label": "PH Training Schedule",
              "description": "Your upcoming bookings and session times.",
              "resourceName": "ph_schedule_widget"
            },
            {
              "name": "PHQuickActions",
              "label": "PH Quick Actions",
              "description": "Quickly start a run, message your coach, or log nutrition.",
              "resourceName": "ph_quick_actions_widget"
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {
        "root": "app"
      },
      "eas": {
        "projectId": "378da946-7b65-473b-9b19-1a0b4e67ea73"
      }
    }
  }
}
