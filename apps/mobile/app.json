{
  "expo": {
    "name": "PH Performance",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "phperformance",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:ph-platform-onboarding.vercel.app",
        "applinks:ph-performance-2cae29f7922d.herokuapp.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIStatusBarHidden": true,
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIBackgroundModes": [
          "remote-notification",
          "location"
        ]
      },
      "bundleIdentifier": "com.clientreachai.phperformance",
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          }
        ],
        "NSPrivacyCollectedDataTypes": [],
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyTracking": false
      }
    },
    "androidStatusBar": {
      "hidden": true,
      "translucent": true,
      "backgroundColor": "#0a0a0b"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0b",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.clientreachai.phperformance",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ph-platform-onboarding.vercel.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ph-performance-2cae29f7922d.herokuapp.com",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "@sentry/react-native/expo",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "react-native-edge-to-edge",
        {
          "android": {
            "parentTheme": "Default",
            "enforceNavigationBarContrast": false
          }
        }
      ],
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0b",
          "dark": {
            "backgroundColor": "#0a0a0b"
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "PH Performance needs microphone access to record training videos with audio."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PH Performance to access your photos and videos so you can send them in messages.",
          "cameraPermission": "Allow PH Performance to access your camera so you can take photos and record videos to send in messages."
        }
      ],
      [
        "expo-image",
        {}
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "PH Performance uses your camera to record training videos and take progress photos."
        }
      ],
      "./plugins/withSSLPinning",
      "expo-secure-store",
      "expo-video",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow this app to track your location during runs.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {
        "root": "app"
      },
      "eas": {
        "projectId": "05e78255-c0dc-481a-85c0-835a4d6502a7"
      }
    }
  }
}
