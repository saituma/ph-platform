# Render deployment environment variables
# Copy these to Render Dashboard → Environment

NODE_ENV=production
PORT=3001

# Neon PostgreSQL (free tier)
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=true

# Auth
AUTH_MODE=jwt
JWT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SUCCESS_URL=https://your-app.vercel.app/payment-success
STRIPE_CANCEL_URL=https://your-app.vercel.app/payment-cancel
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PHP=
STRIPE_PRICE_PHP_PREMIUM=
STRIPE_PRICE_PHP_PLUS=
STRIPE_PRICE_PHP_PRO=
STRIPE_PRICE_PHP_MONTHLY=
STRIPE_PRICE_PHP_PREMIUM_MONTHLY=
STRIPE_PRICE_PHP_PLUS_MONTHLY=
STRIPE_PRICE_PHP_PRO_MONTHLY=
STRIPE_PRICE_PHP_YEARLY=
STRIPE_PRICE_PHP_PREMIUM_YEARLY=
STRIPE_PRICE_PHP_PLUS_YEARLY=
STRIPE_PRICE_PHP_PRO_YEARLY=

# AWS (S3 + CloudFront for media)
S3_BUCKET=
AWS_REGION=
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_ID=
CLOUDFRONT_PRIVATE_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Web admin URL (Vercel)
ADMIN_WEB_URL=https://your-app.vercel.app

# CORS — allow web admin + mobile
CORS_ORIGINS=https://your-app.vercel.app

# Push notifications
EXPO_ACCESS_TOKEN=

# OpenAI
OPEN_AI_API_KEY=
