# Render deployment environment variables
# Copy these to Render Dashboard → Environment

NODE_ENV=production
PORT=3001

# Neon PostgreSQL (free tier) — same URL for the API and `pnpm db:migrate`
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_SSL=true

# Auth (HS256 access tokens issued by the API)
JWT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SUCCESS_URL=https://your-app.vercel.app/payment-success
STRIPE_CANCEL_URL=https://your-app.vercel.app/payment-cancel
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PHP=
STRIPE_PRICE_PHP_PREMIUM=
STRIPE_PRICE_PHP_PLUS=
STRIPE_PRICE_PHP_PRO=
STRIPE_PRICE_PHP_MONTHLY=
STRIPE_PRICE_PHP_PREMIUM_MONTHLY=
STRIPE_PRICE_PHP_PLUS_MONTHLY=
STRIPE_PRICE_PHP_PRO_MONTHLY=
STRIPE_PRICE_PHP_YEARLY=
STRIPE_PRICE_PHP_PREMIUM_YEARLY=
STRIPE_PRICE_PHP_PLUS_YEARLY=
STRIPE_PRICE_PHP_PRO_YEARLY=

# Cloudflare R2 (S3-compatible; keys from R2 → Manage R2 API Tokens)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_REGION=auto
# Public origin for media URLs (R2 custom domain or *.r2.dev)
MEDIA_PUBLIC_BASE_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Web admin URL (Vercel)
ADMIN_WEB_URL=https://your-app.vercel.app

# CORS — allow web admin + mobile
CORS_ORIGINS=https://your-app.vercel.app

# Push notifications
EXPO_ACCESS_TOKEN=

# OpenAI
OPEN_AI_API_KEY=

# Sentry DSN for API error tracking (create a Node.js project at sentry.io)
SENTRY_DSN=

# Cloudflare Turnstile (bot protection on auth routes)
TURNSTILE_SECRET_KEY=

# Redis — Upstash REST API (cache + rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Redis — standard connection URL (BullMQ job queues: email, push notifications)
# Use Upstash ioredis URL or any Redis 6+ instance
REDIS_URL=
