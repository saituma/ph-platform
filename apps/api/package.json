{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "pnpm run test:types && jest",
    "test:watch": "jest --watch",
    "test:types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "lint:eslint": "eslint . --max-warnings=0",
    "format": "biome format --write src test",
    "check": "biome check src test",
    "dev": "nodemon src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc --pretty false",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/run-migrations.ts",
    "db:doctor": "tsx src/scripts/db-doctor.ts",
    "db:migrate:smoke": "bash scripts/migration-smoke.sh",
    "db:psql": "bash -lc 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); ENV_FILE=\"\"; if [ -f \"$ROOT/apps/api/.env\" ]; then ENV_FILE=\"$ROOT/apps/api/.env\"; elif [ -f .env ]; then ENV_FILE=.env; fi; if [ -z \"$ENV_FILE\" ]; then echo \"DATABASE_URL is not set\"; exit 1; fi; DATABASE_URL=$(sed -n \"s/^DATABASE_URL=//p\" \"$ENV_FILE\" | tail -n 1); if [ -z \"$DATABASE_URL\" ]; then echo \"DATABASE_URL is not set\"; exit 1; fi; psql \"$DATABASE_URL\" \"$@\"'",
    "db:migrate:prod": "node dist/scripts/run-migrations.js",
    "seed:admin": "ts-node src/scripts/seed-admin.ts",
    "seed:super-admin": "ts-node src/scripts/set-super-admin.ts",
    "seed:demo": "PH_API_SCRIPT=1 ts-node src/scripts/seed-demo-content.ts",
    "admin:set-password": "ts-node src/scripts/set-admin-password.ts",
    "subscription:expiry-sweep": "PH_API_SCRIPT=1 ts-node src/scripts/check-subscription-expiry.ts",
    "load:palette": "tsx src/scripts/load-command-palette.ts",
    "athletes:clamp-youth-ages": "PH_API_SCRIPT=1 tsx src/scripts/clamp-youth-ages.ts",
    "fix:adult-tiers": "PH_API_SCRIPT=1 tsx src/scripts/fix-adult-tier-modules.ts",
    "stripe:list-plan-prices": "PH_API_SCRIPT=1 tsx src/scripts/list-plan-prices.ts",
    "stripe:list-lookup-prices": "tsx src/scripts/list-stripe-lookup-prices.ts",
    "stripe:verify-plan-prices": "tsx src/scripts/verify-stripe-plan-prices.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.0",
  "dependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@sentry/node": "^10.51.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bullmq": "^5.76.4",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "expo-server-sdk": "^6.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jose": "^5.9.3",
    "minio": "^8.0.6",
    "nodemailer": "^6.10.1",
    "openai": "^6.23.0",
    "pg": "^8.18.0",
    "resend": "^4.0.0",
    "socket.io": "^4.8.1",
    "stripe": "^17.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.30",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.25.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
