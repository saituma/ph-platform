{
  "name": "api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "pnpm run test:types && jest",
    "test:watch": "jest --watch",
    "test:types": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "dev": "nodemon src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:psql": "bash -lc 'ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd); ENV_FILE=\"\"; if [ -f \"$ROOT/apps/api/.env\" ]; then ENV_FILE=\"$ROOT/apps/api/.env\"; elif [ -f .env ]; then ENV_FILE=.env; fi; if [ -z \"$ENV_FILE\" ]; then echo \"DATABASE_URL is not set\"; exit 1; fi; DATABASE_URL=$(sed -n \"s/^DATABASE_URL=//p\" \"$ENV_FILE\" | tail -n 1); if [ -z \"$DATABASE_URL\" ]; then echo \"DATABASE_URL is not set\"; exit 1; fi; psql \"$DATABASE_URL\" \"$@\"'",
    "db:migrate:prod": "node dist/db/migrate.js",
    "seed:admin": "ts-node src/scripts/seed-admin.ts",
    "admin:set-password": "ts-node src/scripts/set-admin-password.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.0",
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.985.0",
    "@aws-sdk/client-dynamodb": "^3.985.0",
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/cloudfront-signer": "^3.985.0",
    "@aws-sdk/lib-dynamodb": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@electric-sql/pglite": "^0.3.15",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "expo-server-sdk": "^6.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jose": "^5.9.3",
    "nodemailer": "^6.10.1",
    "openai": "^6.23.0",
    "pg": "^8.18.0",
    "socket.io": "^4.8.1",
    "stripe": "^17.0.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.30",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "aws-sdk-client-mock": "^4.1.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.25.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
